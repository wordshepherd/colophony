# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://prospector:password@localhost:5432/prospector
DATABASE_TEST_URL=postgresql://test:test@localhost:5433/prospector_test

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Generate with: openssl rand -base64 64
JWT_SECRET=your-secret-key-minimum-64-characters-long-for-security-replace-this
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# =============================================================================
# FILE STORAGE (MinIO / S3)
# =============================================================================
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=submissions
S3_QUARANTINE_BUCKET=quarantine
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# =============================================================================
# FILE UPLOADS (tusd)
# =============================================================================
# tusd endpoint for resumable uploads (leave empty to use presigned S3 URLs)
TUS_ENDPOINT=http://localhost:1080
# Shared secret for tusd webhook authentication (generate with: openssl rand -hex 32)
TUS_HOOK_SECRET=

# =============================================================================
# STRIPE (Payments)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# =============================================================================
# EMAIL
# =============================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
EMAIL_FROM=noreply@yourmagazine.com

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
PORT=4000

# Frontend URL (for CORS and email links)
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# API URL (for frontend to call)
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000

# =============================================================================
# RATE LIMITING
# =============================================================================
# Default: requests per minute for general endpoints
RATE_LIMIT_DEFAULT_MAX=100
# Auth: requests per minute for auth endpoints (stricter)
RATE_LIMIT_AUTH_MAX=20

# =============================================================================
# VIRUS SCANNING (ClamAV - optional for dev)
# =============================================================================
# Leave CLAMAV_HOST empty in development to skip scanning (files assumed clean)
# To enable scanning: docker-compose --profile full up
CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=30000
