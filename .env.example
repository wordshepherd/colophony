# =============================================================================
# DATABASE
# =============================================================================
# Direct connection (port 5432) — used for migrations: pnpm db:generate, pnpm db:migrate
DATABASE_URL=postgresql://colophony:password@localhost:5432/colophony
# PgBouncer connection (port 6432) — used for runtime API queries with RLS
# Run `docker compose up pgbouncer` for connection pooling
DATABASE_APP_URL=postgresql://app_user:app_password@localhost:6432/colophony
DATABASE_TEST_URL=postgresql://test:test@localhost:5433/colophony_test
# DB_SSL=false            # false | true | no-verify
# DB_SSL_CA_PATH=         # CA cert path (when DB_SSL=true)
# DB_ADMIN_POOL_MAX=5     # Superuser pool (migrations, admin)
# DB_APP_POOL_MAX=20      # App pool (request traffic, RLS)

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTHENTICATION (Zitadel OIDC)
# =============================================================================
# Backend: Zitadel authority URL and client ID for token validation
ZITADEL_AUTHORITY=http://localhost:8080
ZITADEL_CLIENT_ID=

# Frontend: public env vars for OIDC Authorization Code flow with PKCE
NEXT_PUBLIC_ZITADEL_AUTHORITY=http://localhost:8080
NEXT_PUBLIC_ZITADEL_CLIENT_ID=

# =============================================================================
# FILE STORAGE (MinIO / S3)
# =============================================================================
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=submissions
S3_QUARANTINE_BUCKET=quarantine
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# =============================================================================
# FILE UPLOADS (tusd)
# =============================================================================
# tusd endpoint for resumable uploads (leave empty to use presigned S3 URLs)
TUS_ENDPOINT=http://localhost:1080/files/
# Shared secret for tusd webhook authentication (generate with: openssl rand -hex 32)
TUS_HOOK_SECRET=

# =============================================================================
# STRIPE (Payments)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# =============================================================================
# EMAIL
# =============================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
EMAIL_FROM=noreply@yourmagazine.com

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
PORT=4000

# Frontend URL (for CORS and email links)
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# API URL (for frontend to call)
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000
# tusd endpoint for resumable uploads (frontend)
NEXT_PUBLIC_TUS_URL=http://localhost:1080/files/

# =============================================================================
# RATE LIMITING
# =============================================================================
# Unauthenticated: requests per window (keyed by IP)
RATE_LIMIT_DEFAULT_MAX=60
# Authenticated: requests per window (keyed by userId)
RATE_LIMIT_AUTH_MAX=200
# Window size in seconds
RATE_LIMIT_WINDOW_SECONDS=60
# Redis key prefix (change per environment to prevent collisions)
RATE_LIMIT_KEY_PREFIX=colophony:rl

# =============================================================================
# VIRUS SCANNING (ClamAV - optional for dev)
# =============================================================================
# Leave CLAMAV_HOST empty in development to skip scanning (files assumed clean)
# To enable scanning: docker-compose --profile full up
CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=30000

# =============================================================================
# MONITORING (optional)
# =============================================================================
# Sentry error tracking — set DSN to enable
# SENTRY_DSN=https://your-dsn@sentry.io/project
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0
# SENTRY_RELEASE=

# Prometheus metrics — set to true to enable /metrics endpoint
# METRICS_ENABLED=false
# Start monitoring stack: docker compose --profile monitoring up -d
# Grafana: http://localhost:3001 (admin/admin)
