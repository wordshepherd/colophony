# =============================================================================
# Prospector Staging Environment Variables
# Copy to .env.staging and fill in values before deploying
# =============================================================================
# Staging mirrors production config with:
# - Test Stripe keys (sk_test_, pk_test_)
# - Debug-level logging
# - Lower resource limits
# - Same RLS / auth / security patterns as production

# === REQUIRED ===

DOMAIN=staging.submissions.example.com

# PostgreSQL superuser credentials
POSTGRES_USER=prospector
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_48
POSTGRES_DB=prospector_staging

# Application database user (non-superuser, required for RLS)
APP_USER_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_48

# JWT secret (minimum 64 characters)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Redis password
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_48

# MinIO credentials
MINIO_ROOT_USER=CHANGE_ME_generate_with_openssl_rand_hex_16
MINIO_ROOT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_48

# tusd webhook secret
TUS_HOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# === STAGING-SPECIFIC ===

# Use Stripe TEST keys (not live!)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Debug logging for staging
LOG_LEVEL=debug

# === OPTIONAL: Email ===

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@staging.example.com

# === OPTIONAL: Rate Limiting (relaxed for testing) ===

RATE_LIMIT_DEFAULT_MAX=200
RATE_LIMIT_AUTH_MAX=50

# === OPTIONAL: Port ===

HTTP_PORT=80
