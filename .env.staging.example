# =============================================================================
# Colophony Staging Environment Variables
# Copy to .env.staging and fill in values before deploying
# =============================================================================
# Staging mirrors production config with:
# - Test Stripe keys (sk_test_, pk_test_)
# - Debug-level logging
# - Lower resource limits
# - Same RLS / auth / security patterns as production

# === REQUIRED ===

DOMAIN=staging.colophony.pub

# PostgreSQL superuser credentials
POSTGRES_USER=colophony
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_48
POSTGRES_DB=colophony_staging

# Application database user (non-superuser, required for RLS)
APP_USER_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_48

# Redis password
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_48

# Garage S3-compatible storage
GARAGE_RPC_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
GARAGE_ADMIN_TOKEN=CHANGE_ME_generate_with_openssl_rand_base64_32
GARAGE_S3_ACCESS_KEY=CHANGE_ME_must_be_GK_plus_24_hex_chars
GARAGE_S3_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# tusd webhook secret
TUS_HOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# === AUTH (Zitadel Cloud) ===

ZITADEL_AUTHORITY=https://your-instance.zitadel.cloud
ZITADEL_CLIENT_ID=your_client_id
ZITADEL_WEBHOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Frontend build args (must match Zitadel values above)
NEXT_PUBLIC_ZITADEL_AUTHORITY=https://your-instance.zitadel.cloud
NEXT_PUBLIC_ZITADEL_CLIENT_ID=your_client_id

# === STAGING-SPECIFIC ===

# Use Stripe TEST keys (not live!)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Debug logging for staging
LOG_LEVEL=debug

# === BACKGROUND JOBS (Inngest Cloud) ===

INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key

# === OPTIONAL: Email ===

EMAIL_PROVIDER=none
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@staging.example.com

# === OPTIONAL: Monitoring ===

SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
METRICS_ENABLED=true
SLACK_WEBHOOK_URL=
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
# ZITADEL_SERVICE_TOKEN=

# === OPTIONAL: Federation ===

FEDERATION_ENABLED=false

# === OPTIONAL: Rate Limiting (relaxed for testing) ===

RATE_LIMIT_DEFAULT_MAX=200
RATE_LIMIT_AUTH_MAX=50

# === OPTIONAL: Ports ===

HTTP_PORT=80
HTTPS_PORT=443

# === OPTIONAL: Backups (WAL-G to S3) ===
# Uncomment and fill to enable continuous PostgreSQL backups.
# See docs/deployment.md for provider examples.
#
# BACKUP_S3_PREFIX=s3://your-bucket/colophony-staging
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_FORCE_PATH_STYLE=false
