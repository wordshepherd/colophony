# =============================================================================
# Colophony Production Environment Variables
# Copy to .env.prod and fill in values before deploying
# =============================================================================

# === REQUIRED ===

# Domain name (used for CORS, URLs, and nginx)
DOMAIN=submissions.example.com

# PostgreSQL superuser credentials
POSTGRES_USER=colophony
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_48
POSTGRES_DB=colophony

# Application database user (non-superuser, required for RLS)
APP_USER_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_48

# JWT secret for authentication (minimum 64 characters)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Redis password
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_48

# MinIO (S3-compatible storage) credentials
MINIO_ROOT_USER=CHANGE_ME_generate_with_openssl_rand_hex_16
MINIO_ROOT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_48

# tusd webhook authentication secret
TUS_HOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# === OPTIONAL: Payments (Stripe) ===

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# === OPTIONAL: Email ===

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com

# === OPTIONAL: Rate Limiting ===

RATE_LIMIT_DEFAULT_MAX=100
RATE_LIMIT_AUTH_MAX=20

# === OPTIONAL: Port ===

# Change if port 80 is already in use
HTTP_PORT=80
