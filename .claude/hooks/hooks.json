{
  "hooks": {
    "PreToolUse": [
      {
        "event": "Edit(*.ts)",
        "script": ".claude/hooks/pre-edit-validate.js"
      },
      {
        "event": "Edit(**/*payment*.ts)",
        "script": ".claude/hooks/pre-payment-validate.js"
      },
      {
        "event": "Edit(**/*stripe*.ts)",
        "script": ".claude/hooks/pre-payment-validate.js"
      },
      {
        "event": "Edit(**/*webhook*.ts)",
        "script": ".claude/hooks/pre-payment-validate.js"
      },
      {
        "event": "Edit(apps/web/**/*.tsx)",
        "script": ".claude/hooks/pre-frontend-validate.js"
      },
      {
        "event": "Write(apps/web/**/*.tsx)",
        "script": ".claude/hooks/pre-frontend-validate.js"
      },
      {
        "event": "Edit(**/routes/*.ts)",
        "script": ".claude/hooks/pre-router-audit.js"
      },
      {
        "event": "Write(**/routes/*.ts)",
        "script": ".claude/hooks/pre-router-audit.js"
      },
      {
        "event": "Edit(**/*.route.ts)",
        "script": ".claude/hooks/pre-router-audit.js"
      },
      {
        "event": "Write(**/*.route.ts)",
        "script": ".claude/hooks/pre-router-audit.js"
      },
      {
        "event": "Edit(**/*.handler.ts)",
        "script": ".claude/hooks/pre-router-audit.js"
      },
      {
        "event": "Write(**/*.handler.ts)",
        "script": ".claude/hooks/pre-router-audit.js"
      },
      {
        "event": "Bash(git push*)",
        "script": ".claude/hooks/pre-push-branch.js"
      }
    ],
    "PostToolUse": [
      {
        "event": "Edit(apps/**/*.ts)",
        "script": ".claude/hooks/post-edit-lint.js"
      },
      {
        "event": "Write(apps/**/*.ts)",
        "script": ".claude/hooks/post-edit-lint.js"
      },
      {
        "event": "Edit(apps/**/*.tsx)",
        "script": ".claude/hooks/post-edit-lint.js"
      },
      {
        "event": "Write(apps/**/*.tsx)",
        "script": ".claude/hooks/post-edit-lint.js"
      },
      {
        "event": "Edit(**/schema/*.ts)",
        "script": ".claude/hooks/post-schema.js"
      },
      {
        "event": "Write(**/schema/*.ts)",
        "script": ".claude/hooks/post-schema.js"
      },
      {
        "event": "Edit(**/*email*template*.ts)",
        "script": ".claude/hooks/post-email-template.js"
      },
      {
        "event": "Edit(**/migrations/**/*.sql)",
        "script": ".claude/hooks/post-migration-validate.js"
      },
      {
        "event": "Write(**/migrations/**/*.sql)",
        "script": ".claude/hooks/post-migration-validate.js"
      },
      {
        "event": "Edit(**/drizzle/**/*.sql)",
        "script": ".claude/hooks/post-migration-validate.js"
      },
      {
        "event": "Write(**/drizzle/**/*.sql)",
        "script": ".claude/hooks/post-migration-validate.js"
      },
      {
        "event": "Bash(git commit*)",
        "script": ".claude/hooks/post-commit-devlog.js"
      },
      {
        "event": "Edit(**/*.spec.ts)",
        "script": ".claude/hooks/post-test-file.js"
      },
      {
        "event": "Write(**/*.spec.ts)",
        "script": ".claude/hooks/post-test-file.js"
      },
      {
        "event": "Edit(**/*.spec.tsx)",
        "script": ".claude/hooks/post-test-file.js"
      },
      {
        "event": "Write(**/*.spec.tsx)",
        "script": ".claude/hooks/post-test-file.js"
      },
      {
        "event": "Edit(**/*.test.ts)",
        "script": ".claude/hooks/post-test-file.js"
      },
      {
        "event": "Write(**/*.test.ts)",
        "script": ".claude/hooks/post-test-file.js"
      },
      {
        "event": "Edit(**/e2e/**/*.ts)",
        "script": ".claude/hooks/post-test-file.js"
      },
      {
        "event": "Write(**/e2e/**/*.ts)",
        "script": ".claude/hooks/post-test-file.js"
      }
    ]
  }
}
