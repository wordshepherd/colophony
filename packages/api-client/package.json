  },
  "devDependencies": {
    "@colophony/typescript-config": "workspace:*",
    "@types/node": "^25.5.0",
    "typescript": "^5.7.2",
    "@vitest/coverage-v8": "^4.1.0",
    "vitest": "^4.1.0"
  }
}
