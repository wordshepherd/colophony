{
  "name": "@colophony/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "check": "drizzle-kit check",
    "studio": "drizzle-kit studio",
    "seed": "tsx src/seed.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@prospector/typescript-config": "workspace:*",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
