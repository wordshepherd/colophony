      "patch": {
        "operationId": "updateSubmissionStatus",
        "summary": "Update submission status",
        "description": "Transition a submission to a new status. Requires EDITOR or ADMIN role. Valid transitions depend on current status.",
        "tags": ["Submissions"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
