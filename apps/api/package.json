{
  "name": "@colophony/api",
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "main": "./dist/main.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "default": "./dist/main.js"
    },
    "./trpc": {
      "default": "./dist/trpc/router.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch --env-file-if-exists=.env src/main.ts",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint --max-warnings 0 \"{src,test}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:rls": "vitest run --config vitest.config.rls.ts",
    "test:security": "vitest run --config vitest.config.security.ts",
    "test:services": "vitest run --config vitest.config.services.ts",
    "test:webhooks": "vitest run --config vitest.config.webhooks.ts",
    "test:queues": "vitest run --config vitest.config.queues.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@colophony/api-contracts": "workspace:*",
    "@colophony/auth-client": "workspace:*",
    "@colophony/db": "workspace:*",
    "@colophony/plugin-sdk": "workspace:^",
    "@colophony/types": "workspace:*",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@orpc/openapi": "^1.13.14",
    "@orpc/server": "^1.13.14",
    "@orpc/zod": "^1.13.14",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.49.0",
    "@trpc/server": "^11.16.0",
    "archiver": "^7.0.1",
    "bullmq": "^5.74.1",
    "clamscan": "^2.4.0",
    "docx": "^9.6.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.0.0",
    "fastify-raw-body": "^5.0.0",
    "htmlparser2": "^12.0.0",
    "inngest": "^4.2.4",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "mammoth": "^1.12.0",
    "mjml": "^4.18.0",
    "nodemailer": "^8.0.5",
    "p-limit": "^7.3.0",
    "prom-client": "^15.1.3",
    "sanitize-html": "^2.17.3",
    "stripe": "^21.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@colophony/typescript-config": "workspace:*",
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^10.4.0",
    "@types/archiver": "^7.0.0",
    "@types/clamscan": "^2.4.1",
    "@types/ioredis-mock": "^8.2.7",
    "@types/mjml": "^4.7.4",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "ioredis-mock": "^8.13.1",
    "pg": "^8.20.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
