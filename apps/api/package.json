{
  "name": "@colophony/api",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/main.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "default": "./dist/main.js"
    },
    "./trpc": {
      "default": "./dist/trpc/router.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:rls": "vitest run --config vitest.config.rls.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "@colophony/auth-client": "workspace:*",
    "@colophony/db": "workspace:*",
    "@colophony/types": "workspace:*",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@trpc/server": "^10.45.0",
    "archiver": "^7.0.1",
    "bullmq": "^5.69.2",
    "clamscan": "^2.4.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.9.3",
    "nodemailer": "^7.0.13",
    "stripe": "^20.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@colophony/eslint-config": "workspace:*",
    "@colophony/typescript-config": "workspace:*",
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^8.4.0",
    "@types/archiver": "^7.0.0",
    "@types/clamscan": "^2.4.1",
    "@types/ioredis-mock": "^8.2.6",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.11.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "ioredis-mock": "^8.13.1",
    "pg": "^8.13.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  }
}
