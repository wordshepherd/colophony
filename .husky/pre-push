# WSL: node/pnpm aren't in husky's default sh PATH; add nvm node
NVM_NODE="$HOME/.nvm/versions/node"
for d in "$NVM_NODE"/*/bin; do
  PATH="$d:$PATH"
done
export PATH

# Run the same checks CI runs, so failures are caught before pushing
echo "Running pre-push checks..."

echo "→ Type checking..."
# Scoped to API + DB during v2 rewrite (web app excluded)
pnpm turbo run type-check --filter=@colophony/db --filter=@colophony/api || {
  echo "Type check failed. Fix errors before pushing."
  exit 1
}

echo "→ Linting..."
pnpm lint || {
  echo "Lint failed. Fix errors before pushing."
  exit 1
}

echo "Pre-push checks passed."
